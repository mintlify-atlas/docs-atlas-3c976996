  "keyFeatures": [
    "Fast context switching between Kubernetes clusters",
    "Quick namespace switching within contexts",
    "Interactive fuzzy search with fzf integration",
    "Context and namespace history with '-' command",
    "Context renaming and deletion",
    "Shell completion for bash/zsh/fish",
    "Available as kubectl plugins",
    "Cross-platform support (Linux, macOS, Windows)",
    "Written in Go for performance",
    "Colorized output with customization"
  ],
  "publicApiSurface": [
    "kubectx - list contexts",
    "kubectx <NAME> - switch to context",
    "kubectx - - switch to previous context",
    "kubectx -c, --current - show current context",
    "kubectx <NEW>=<OLD> - rename context",
    "kubectx -d <NAME> - delete context",
    "kubectx -u, --unset - unset current context",
    "kubens - list namespaces",
    "kubens <NAME> - switch to namespace",
    "kubens - - switch to previous namespace",
    "kubens -c, --current - show current namespace",
    "kubens <NAME> --force - force switch to namespace"
  ]
